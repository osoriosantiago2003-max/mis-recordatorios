# Copia este archivo a ".env.local" y pega tus llaves reales de Supabase.
# Las encuentras en: Supabase > tu proyecto > Project Settings > API
VITE_SUPABASE_URL=https://TU-PROYECTO.supabase.co
VITE_SUPABASE_ANON_KEY=tu-clave-publica-anon

# Llave pública para notificaciones push (la genera: npx web-push generate-vapid-keys)
VITE_VAPID_PUBLIC_KEY=tu-llave-publica-vapid
